        {
          "name": "NotLike",
          "type": "Bool",
          "isMandatory": true,
          "defaultValue": "",
          "description": "Indicates that this cmdlet gets objects if the property value doesn't match a value that includes wildcard characters (`*`). For example: `Get-Process | Where-Object ProcessName -NotLike \"*host\"` This parameter was introduced in Windows PowerShell 3.0.",
          "validValues": [],
          "value": "",
          "isPipelineInput": false,
          "parameterSets": [
            "NotLikeSet"

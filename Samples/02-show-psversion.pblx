        {
          "name": "CLike",
          "type": "Bool",
          "isMandatory": true,
          "defaultValue": "",
          "description": "Indicates that this cmdlet gets objects if the property value matches a value that includes wildcard characters (\u0060*\u0060). This operation is case-sensitive. For example: \u0060Get-Process | Where-Object ProcessName -CLike \u0022*host\u0022\u0060 This parameter was introduced in Windows PowerShell 3.0.",
          "validValues": [],

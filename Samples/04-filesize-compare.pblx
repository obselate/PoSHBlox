          "description": "Objects to display in the host.",
          "validValues": [],
          "value": "small: $($_.Name)",
          "isPipelineInput": true,
          "parameterSets": [],
          "mandatoryInSets": []
        },
        {
          "name": "NoNewline",
          "type": "Bool",

{
  "description": "Reference manifest for Templates/Builtin/*.json. Run with `PoSHBlox --regen-manifest scripts/builtin-catalog.json` on a Windows host that has the listed modules available. Control-flow / annotation / custom catalogs are hand-curated (not introspectable) and are not listed here.",
  "targets": [
    {
      "outputFile": "Templates/Builtin/FileFolder.json",
      "category": "File / Folder",
      "sources": [
        {
          "module": "Microsoft.PowerShell.Management",
          "cmdlets": [
            "Get-ChildItem",
            "Get-Item",
            "Copy-Item",
            "Move-Item",
            "Remove-Item",
            "Rename-Item",
            "New-Item",
            "Test-Path",
            "Resolve-Path",
            "Get-Content",
            "Set-Content",
            "Add-Content",
            "Clear-Content"
          ]
        },
        {
          "module": "Microsoft.PowerShell.Management",
          "cmdlets": [ "Join-Path", "Split-Path" ]
        },
        {
          "module": "Microsoft.PowerShell.Security",
          "cmdlets": [ "Get-Acl", "Set-Acl" ]
        }
      ]
    },
    {
      "outputFile": "Templates/Builtin/ProcessService.json",
      "category": "Process / Service",
      "sources": [
        {
          "module": "Microsoft.PowerShell.Management",
          "cmdlets": [
            "Get-Process",
            "Start-Process",
            "Stop-Process",
            "Wait-Process",
            "Get-Service",
            "Start-Service",
            "Stop-Service",
            "Restart-Service",
            "Set-Service"
          ]
        }
      ]
    },
    {
      "outputFile": "Templates/Builtin/Registry.json",
      "category": "Registry",
      "sources": [
        {
          "module": "Microsoft.PowerShell.Management",
          "cmdlets": [
            "Get-ItemProperty",
            "Set-ItemProperty",
            "New-ItemProperty",
            "Clear-ItemProperty",
            "Remove-ItemProperty",
            "New-Item"
          ]
        }
      ]
    },
    {
      "outputFile": "Templates/Builtin/NetworkRemote.json",
      "category": "Network / Remote",
      "sources": [
        {
          "module": "Microsoft.PowerShell.Management",
          "cmdlets": [ "Test-Connection" ]
        },
        {
          "module": "Microsoft.PowerShell.Core",
          "cmdlets": [ "Invoke-Command" ]
        },
        {
          "module": "Microsoft.PowerShell.Utility",
          "cmdlets": [ "Invoke-WebRequest", "Invoke-RestMethod" ]
        },
        {
          "module": "NetTCPIP",
          "cmdlets": [ "Test-NetConnection", "Get-NetIPAddress" ]
        },
        {
          "module": "NetAdapter",
          "cmdlets": [ "Get-NetAdapter" ]
        },
        {
          "module": "DnsClient",
          "cmdlets": [ "Resolve-DnsName" ]
        }
      ]
    },
    {
      "outputFile": "Templates/Builtin/StringData.json",
      "category": "String / Data",
      "sources": [
        {
          "module": "Microsoft.PowerShell.Core",
          "cmdlets": [ "Where-Object", "ForEach-Object" ]
        },
        {
          "module": "Microsoft.PowerShell.Utility",
          "cmdlets": [
            "Select-Object",
            "Sort-Object",
            "Group-Object",
            "Measure-Object",
            "Compare-Object",
            "Select-String",
            "ConvertTo-Json",
            "ConvertFrom-Json",
            "Export-Csv",
            "Import-Csv",
            "ConvertTo-Csv",
            "ConvertFrom-Csv",
            "Out-File",
            "Tee-Object"
          ]
        }
      ]
    },
    {
      "outputFile": "Templates/Builtin/Output.json",
      "category": "Output",
      "sources": [
        {
          "module": "Microsoft.PowerShell.Utility",
          "cmdlets": [
            "Write-Host",
            "Write-Output",
            "Write-Warning",
            "Write-Error",
            "Write-Verbose",
            "Write-Debug",
            "Write-Information",
            "Format-Table",
            "Format-List"
          ]
        },
        {
          "module": "Microsoft.PowerShell.Core",
          "cmdlets": [ "Out-Host", "Out-Null" ]
        }
      ]
    },
    {
      "outputFile": "Templates/Builtin/Utility.json",
      "category": "Utility / Date",
      "sources": [
        {
          "module": "Microsoft.PowerShell.Utility",
          "cmdlets": [
            "Get-Date",
            "Start-Sleep",
            "Measure-Command",
            "Get-Random"
          ]
        },
        {
          "module": "Microsoft.PowerShell.Management",
          "cmdlets": [ "Get-Location", "Set-Location" ]
        }
      ]
    },
    {
      "outputFile": "Templates/Builtin/VariableModule.json",
      "category": "Variable / Module",
      "sources": [
        {
          "module": "Microsoft.PowerShell.Utility",
          "cmdlets": [ "Get-Variable", "Set-Variable" ]
        },
        {
          "module": "Microsoft.PowerShell.Core",
          "cmdlets": [
            "Get-Module",
            "Import-Module",
            "Remove-Module"
          ]
        }
      ]
    },
    {
      "outputFile": "Templates/Builtin/Security.json",
      "category": "Security",
      "sources": [
        {
          "module": "Microsoft.PowerShell.Security",
          "cmdlets": [
            "Get-Credential",
            "ConvertTo-SecureString",
            "ConvertFrom-SecureString"
          ]
        }
      ]
    }
  ]
}

<uiw:AppWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:uiw="using:FluentAvalonia.UI.Windowing"
        xmlns:vm="using:PoSHBlox.ViewModels"
        x:Class="PoSHBlox.Views.ImportModuleWindow"
        Title="PoSHBlox — Import"
        Width="620" Height="700"
        Background="{DynamicResource BgPrimaryBrush}"
        FontFamily="{DynamicResource FontMono}"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <uiw:AppWindow.DataContext>
        <vm:ImportModuleViewModel />
    </uiw:AppWindow.DataContext>

    <DockPanel Margin="16">

        <!-- Search + Refresh -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right" Content="Refresh" Margin="8,0,0,0"
                    Command="{Binding RefreshModulesCommand}"
                    IsEnabled="{Binding !IsLoadingModules}"
                    ToolTip.Tip="Re-scan Get-Module -ListAvailable on every detected host"
                    Padding="12,7" CornerRadius="4"
                    Background="{DynamicResource BgSecondaryBrush}"
                    Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBox Text="{Binding SearchText, Mode=TwoWay}" Watermark="Filter modules…"
                     Background="{DynamicResource BgSecondaryBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderPrimaryBrush}"
                     Padding="8,7" CornerRadius="3" FontSize="12" />
        </DockPanel>

        <!-- Status line -->
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" FontSize="11"
                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0"
                   TextWrapping="Wrap" />

        <!-- Save row -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <TextBox DockPanel.Dock="Left" Width="240"
                     Text="{Binding CategoryName, Mode=TwoWay}" Watermark="Category name"
                     Background="{DynamicResource BgSecondaryBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderPrimaryBrush}"
                     Padding="8,7" CornerRadius="3" FontSize="12" />
            <Button DockPanel.Dock="Right" Content="Save Selected" HorizontalAlignment="Right"
                    Command="{Binding SaveSelectedCommand}"
                    ToolTip.Tip="Save selected cmdlets as node templates"
                    Padding="14,7" CornerRadius="4"
                    Background="{DynamicResource BgSaveTintBrush}"
                    Foreground="{DynamicResource TextFileBrush}">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource CoreBlueSteel700}" />
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource CoreBlueSteel900}" />
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource CoreBlueBright200}" />
                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource CoreBlueBright300}" />
                </Button.Resources>
            </Button>
        </DockPanel>

        <!-- Separator -->
        <Border DockPanel.Dock="Bottom" Height="1" Background="{DynamicResource BorderPrimaryBrush}" Margin="0,8" />

        <!-- Discovered cmdlets label -->
        <TextBlock DockPanel.Dock="Bottom" Text="DISCOVERED CMDLETS" FontSize="11" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,4" />

        <!-- Cmdlet list with checkboxes -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource BgSecondaryBrush}" CornerRadius="4"
                BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="1"
                Height="220">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding DiscoveredCmdlets}" Margin="4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="6,4" Margin="0,1" CornerRadius="3"
                                    Background="Transparent">
                                <DockPanel>
                                    <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <StackPanel Spacing="1">
                                        <TextBlock Text="{Binding Name}" FontSize="12"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding Description}" FontSize="10"
                                                   Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Available modules label -->
        <TextBlock DockPanel.Dock="Top" Text="AVAILABLE MODULES" FontSize="11" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,4" />

        <!-- Module picker (fills remaining space) -->
        <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="4"
                BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="1">
            <ListBox ItemsSource="{Binding FilteredModules}"
                     SelectedItem="{Binding SelectedModule, Mode=TwoWay}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel LastChildFill="True">
                            <!-- Right-aligned rectangular badge, visible only when edition-exclusive -->
                            <Border DockPanel.Dock="Right" CornerRadius="3"
                                    Padding="6,2" Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding HasBadge}"
                                    BorderThickness="1">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource CoreAmberAction900}" />
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="{StaticResource CoreAmberAction700}" />
                                </Border.BorderBrush>
                                <TextBlock Text="{Binding BadgeText}" FontSize="10">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="{StaticResource CoreAmberAction300}" />
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </Border>
                            <StackPanel Spacing="1">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left" Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding Version}" FontSize="10" Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </DockPanel>
                                <TextBlock Text="{Binding Description}" FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}" TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

    </DockPanel>
</uiw:AppWindow>

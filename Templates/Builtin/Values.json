{
  "category": "Values",
  "templates": [
    {
      "name": "$true",
      "description": "Boolean true literal.",
      "kind": "Value",
      "valueExpression": "$true",
      "dataOutputs": [{ "name": "Out", "type": "Bool", "isPrimary": true }]
    },
    {
      "name": "$false",
      "description": "Boolean false literal.",
      "kind": "Value",
      "valueExpression": "$false",
      "dataOutputs": [{ "name": "Out", "type": "Bool", "isPrimary": true }]
    },
    {
      "name": "$null",
      "description": "Null literal.",
      "kind": "Value",
      "valueExpression": "$null",
      "dataOutputs": [{ "name": "Out", "type": "Any", "isPrimary": true }]
    },
    {
      "name": "$PSScriptRoot",
      "description": "Directory containing the running script. Empty at the console.",
      "kind": "Value",
      "valueExpression": "$PSScriptRoot",
      "dataOutputs": [{ "name": "Out", "type": "Path", "isPrimary": true }]
    },
    {
      "name": "$PSCommandPath",
      "description": "Full path of the running script. Empty at the console.",
      "kind": "Value",
      "valueExpression": "$PSCommandPath",
      "dataOutputs": [{ "name": "Out", "type": "Path", "isPrimary": true }]
    },
    {
      "name": "$HOME",
      "description": "Current user's home directory.",
      "kind": "Value",
      "valueExpression": "$HOME",
      "dataOutputs": [{ "name": "Out", "type": "Path", "isPrimary": true }]
    },
    {
      "name": "$PWD",
      "description": "Current working directory (PathInfo).",
      "kind": "Value",
      "valueExpression": "$PWD",
      "dataOutputs": [{ "name": "Out", "type": "Path", "isPrimary": true }]
    },
    {
      "name": "$PROFILE",
      "description": "Path to the current user's PowerShell profile.",
      "kind": "Value",
      "valueExpression": "$PROFILE",
      "dataOutputs": [{ "name": "Out", "type": "Path", "isPrimary": true }]
    },
    {
      "name": "$PID",
      "description": "Process ID of the current PowerShell host.",
      "kind": "Value",
      "valueExpression": "$PID",
      "dataOutputs": [{ "name": "Out", "type": "Int", "isPrimary": true }]
    },
    {
      "name": "$LASTEXITCODE",
      "description": "Exit code of the last native command. Useful for retry / conditional logic.",
      "kind": "Value",
      "valueExpression": "$LASTEXITCODE",
      "dataOutputs": [{ "name": "Out", "type": "Int", "isPrimary": true }]
    },
    {
      "name": "$IsWindows",
      "description": "True when running on Windows.",
      "kind": "Value",
      "valueExpression": "$IsWindows",
      "dataOutputs": [{ "name": "Out", "type": "Bool", "isPrimary": true }]
    },
    {
      "name": "$IsLinux",
      "description": "True when running on Linux.",
      "kind": "Value",
      "valueExpression": "$IsLinux",
      "dataOutputs": [{ "name": "Out", "type": "Bool", "isPrimary": true }]
    },
    {
      "name": "$IsMacOS",
      "description": "True when running on macOS.",
      "kind": "Value",
      "valueExpression": "$IsMacOS",
      "dataOutputs": [{ "name": "Out", "type": "Bool", "isPrimary": true }]
    },
    {
      "name": "$PSVersionTable",
      "description": "Hashtable describing the running PowerShell version / edition / build. Pipe through an Enumerate node to filter row-by-row with Where-Object / Select-Object.",
      "kind": "Value",
      "valueExpression": "$PSVersionTable",
      "dataOutputs": [{ "name": "Out", "type": "HashTable", "isPrimary": true }]
    },
    {
      "name": "$env:",
      "description": "Environment variable read (parametric). Type the variable name in the properties panel — the node re-titles as $env:<name>.",
      "kind": "Value",
      "valueExpression": "$env:{0}",
      "dataOutputs": [{ "name": "Out", "type": "String", "isPrimary": true }],
      "parameters": [
        {
          "name": "VariableName",
          "type": "String",
          "defaultValue": "ComputerName",
          "description": "Name of the environment variable (no $env: prefix). Examples: ComputerName, UserName, Path."
        }
      ]
    }
  ]
}

<uiw:AppWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:uiw="using:FluentAvalonia.UI.Windowing"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:vm="using:PoSHBlox.ViewModels"
        xmlns:ctrl="using:PoSHBlox.Controls"
        x:Class="PoSHBlox.MainWindow"
        x:Name="RootWindow"
        Title="{Binding WindowTitle, FallbackValue='PoSHBlox'}"
        Width="1280" Height="720"
        Background="{DynamicResource BgPrimaryBrush}"
        FontFamily="{DynamicResource FontMono}"
        WindowStartupLocation="CenterScreen">

    <uiw:AppWindow.DataContext>
        <vm:GraphCanvasViewModel />
    </uiw:AppWindow.DataContext>

    <uiw:AppWindow.Styles>
        <!-- Cheat sheet row styles — target by class, idiomatic Avalonia. -->
        <Style Selector="TextBlock.cheatKey">
            <Setter Property="FontFamily" Value="{DynamicResource FontMono}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFileBrush}" />
        </Style>
        <Style Selector="TextBlock.cheatLabel">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>

        <!-- Quick-add: arrow-key selected item gets an accent background. -->
        <Style Selector="Button.quickAddSelected">
            <Setter Property="Background" Value="{DynamicResource BgSaveTintBrush}" />
        </Style>

        <!-- Tag filter chips — inactive = muted slate, active = saved-tint accent. -->
        <Style Selector="ToggleButton.tagChip">
            <Setter Property="Background" Value="{DynamicResource BgSecondaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="ToggleButton.tagChip:checked">
            <Setter Property="Background" Value="{DynamicResource BgSaveTintBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFileBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BgSaveTintBrush}" />
        </Style>
        <Style Selector="ToggleButton.tagChip:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BgSaveTintBrush}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TextFileBrush}" />
        </Style>

        <!-- Node-graph context menu items — inherit the app's slate palette.
             Monospace header keeps the trailing shortcut hint right-aligned. -->
        <Style Selector="MenuItem.graphCtx">
            <Setter Property="FontFamily" Value="{DynamicResource FontMono}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="12,6" />
        </Style>
        <Style Selector="MenuItem.graphCtx:pointerover">
            <Setter Property="Background" Value="{DynamicResource BgSaveTintBrush}" />
        </Style>
    </uiw:AppWindow.Styles>

    <Grid>
    <DockPanel>
        <!-- ══════ Title bar separator ══════ -->
        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource BorderPrimaryBrush}" />

        <!-- ══════ Top: CommandBar Toolbar ══════ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgPrimaryBrush}"
                BorderBrush="{DynamicResource BorderPrimaryBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,3">
            <StackPanel Orientation="Horizontal" Spacing="3">
                <Button Click="OnNewClicked" Padding="10,6" CornerRadius="4"
                        ToolTip.Tip="New blank graph (Ctrl+N)"
                        Background="{DynamicResource BgSaveTintBrush}"
                        Foreground="{DynamicResource TextFileBrush}">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource CoreBlueSteel700}" />
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource CoreBlueSteel900}" />
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource CoreBlueBright200}" />
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource CoreBlueBright300}" />
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="New" VerticalAlignment="Center" />
                        <ui:SymbolIcon Symbol="Add" FontSize="16" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Click="OnOpenClicked" Padding="10,6" CornerRadius="4"
                        ToolTip.Tip="Open a .pblx project (Ctrl+O)"
                        Background="{DynamicResource BgSaveTintBrush}"
                        Foreground="{DynamicResource TextFileBrush}">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource CoreBlueSteel700}" />
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource CoreBlueSteel900}" />
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource CoreBlueBright200}" />
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource CoreBlueBright300}" />
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Open" VerticalAlignment="Center" />
                        <ui:SymbolIcon Symbol="OpenFile" FontSize="16" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Click="OnSavePblxClicked" Padding="10,6" CornerRadius="4"
                        ToolTip.Tip="Save as .pblx project (Ctrl+S)"
                        Background="{DynamicResource BgSaveTintBrush}"
                        Foreground="{DynamicResource TextFileBrush}">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource CoreBlueSteel700}" />
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource CoreBlueSteel900}" />
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource CoreBlueBright200}" />
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource CoreBlueBright300}" />
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Save" VerticalAlignment="Center" />
                        <ui:SymbolIcon Symbol="Save" FontSize="16" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Click="OnExportPs1Clicked" Padding="10,6" CornerRadius="4"
                        ToolTip.Tip="Export as .ps1 script (Ctrl+E)"
                        Background="{DynamicResource BgSaveTintBrush}"
                        Foreground="{DynamicResource TextFileBrush}">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource CoreBlueSteel700}" />
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource CoreBlueSteel900}" />
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource CoreBlueBright200}" />
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource CoreBlueBright300}" />
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Export" VerticalAlignment="Center" />
                        <ui:SymbolIcon Symbol="Document" FontSize="16" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Click="OnRunClicked" Padding="10,6" CornerRadius="4"
                        ToolTip.Tip="Run generated script in a new PowerShell window (F5)"
                        Background="{DynamicResource BgRunTintBrush}"
                        Foreground="{DynamicResource TextRunBrush}">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource CoreTealAccent700}" />
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource CoreTealAccent900}" />
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource CoreTealAccent200}" />
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource CoreTealAccent300}" />
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Run" VerticalAlignment="Center" />
                        <ui:SymbolIcon Symbol="Play" FontSize="16" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding DeleteSelectedCommand}" Padding="10,6" CornerRadius="4"
                        ToolTip.Tip="Delete selected node (Del)"
                        Background="{DynamicResource BgDeleteTintBrush}"
                        Foreground="{DynamicResource TextDeleteLightBrush}">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource CoreRedWarning700}" />
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource CoreRedWarning900}" />
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource CoreRedWarning200}" />
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource CoreRedWarning300}" />
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Delete" VerticalAlignment="Center" />
                        <ui:SymbolIcon Symbol="Delete" FontSize="16" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Border Width="1" Background="{DynamicResource BorderPrimaryBrush}" Margin="4,2" />
                <ToggleButton IsChecked="{Binding IsPaletteOpen, Mode=TwoWay}" Padding="10,6" CornerRadius="4"
                              ToolTip.Tip="Toggle the node palette sidebar (P)"
                              Background="{DynamicResource BgSaveTintBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}">
                    <ToggleButton.Resources>
                        <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="{StaticResource CoreBlueSteel700}" />
                        <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="{StaticResource CoreBlueSteel600}" />
                        <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed" Color="{StaticResource CoreBlueSteel900}" />
                        <SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="{StaticResource CoreBlueSteel700}" />
                        <SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="{StaticResource CoreBlueSteel900}" />
                        <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="{StaticResource CoreCream}" />
                        <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="{StaticResource CoreCream}" />
                        <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed" Color="{StaticResource CoreCream}" />
                        <SolidColorBrush x:Key="ToggleButtonForegroundPointerOver" Color="{StaticResource CoreCream}" />
                        <SolidColorBrush x:Key="ToggleButtonForegroundPressed" Color="{StaticResource CoreCream}" />
                    </ToggleButton.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Palette" VerticalAlignment="Center" />
                        <ui:SymbolIcon Symbol="List" FontSize="16" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <ToggleButton IsChecked="{Binding IsPreviewOpen, Mode=TwoWay}" Padding="10,6" CornerRadius="4"
                              ToolTip.Tip="View PowerShell script generated from the node graph (Alt+S)"
                              Background="{DynamicResource BgSaveTintBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}">
                    <ToggleButton.Resources>
                        <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="{StaticResource CoreBlueSteel700}" />
                        <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="{StaticResource CoreBlueSteel600}" />
                        <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed" Color="{StaticResource CoreBlueSteel900}" />
                        <SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="{StaticResource CoreBlueSteel700}" />
                        <SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="{StaticResource CoreBlueSteel900}" />
                        <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="{StaticResource CoreCream}" />
                        <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="{StaticResource CoreCream}" />
                        <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed" Color="{StaticResource CoreCream}" />
                        <SolidColorBrush x:Key="ToggleButtonForegroundPointerOver" Color="{StaticResource CoreCream}" />
                        <SolidColorBrush x:Key="ToggleButtonForegroundPressed" Color="{StaticResource CoreCream}" />
                    </ToggleButton.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Script Panel" VerticalAlignment="Center" />
                        <ui:SymbolIcon Symbol="Code" FontSize="16" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <Button Command="{Binding ResetViewCommand}" Padding="10,6" CornerRadius="4"
                        ToolTip.Tip="Reset pan and zoom to default"
                        Background="{DynamicResource BgSaveTintBrush}"
                        Foreground="{DynamicResource TextPrimaryBrush}">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource CoreBlueSteel700}" />
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource CoreBlueSteel900}" />
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource CoreCream}" />
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource CoreCream}" />
                    </Button.Resources>
                    <TextBlock Text="Reset View" VerticalAlignment="Center" />
                </Button>
            </StackPanel>
        </Border>

        <!-- ══════ Main content: Graph area + resizable Script Panel ══════ -->
        <Grid x:Name="MainGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="200" />
            </Grid.RowDefinitions>

            <!-- ── Row 0: SplitView (palette pane) + canvas + properties ── -->
            <SplitView Grid.Row="0"
                       IsPaneOpen="{Binding IsPaletteOpen, Mode=TwoWay}"
                       DisplayMode="CompactInline"
                       OpenPaneLength="320"
                       CompactPaneLength="0"
                       PaneBackground="{DynamicResource BgSurfaceBrush}">

                <!-- Left Pane: Node Palette -->
                <SplitView.Pane>
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="12,10"
                                BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="0,0,0,1">
                            <StackPanel Spacing="8">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="+ Import" Click="OnImportModuleClicked"
                                            ToolTip.Tip="Import cmdlets from an installed PowerShell module"
                                            Padding="8,4" CornerRadius="3" FontSize="11"
                                            Background="{DynamicResource BgSaveTintBrush}"
                                            Foreground="{DynamicResource TextFileBrush}"
                                            VerticalAlignment="Center">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource CoreBlueSteel700}" />
                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource CoreBlueSteel900}" />
                                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource CoreBlueBright200}" />
                                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource CoreBlueBright300}" />
                                        </Button.Resources>
                                    </Button>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="Node Palette" FontSize="15" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Text="(P)" FontSize="12"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </DockPanel>
                                <TextBox x:Name="PaletteSearchBox" Watermark="Search commands... (/)"
                                         Text="{Binding Palette.SearchText, Mode=TwoWay}"
                                         Background="{DynamicResource BgPrimaryBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                         Padding="8,6" CornerRadius="3" FontSize="12" />

                                <!-- Tag filter chips: toggle any combination to narrow the palette. -->
                                <ItemsControl ItemsSource="{Binding Palette.TagChips}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <ToggleButton IsChecked="{Binding IsActive, Mode=TwoWay}"
                                                          Content="{Binding Label}"
                                                          Classes="tagChip"
                                                          Padding="8,3" CornerRadius="10"
                                                          FontSize="10"
                                                          FontFamily="{DynamicResource FontMono}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Palette.FilteredCategories}" Margin="0,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2">
                                            <!-- Clickable category header -->
                                            <Button Click="OnCategoryHeaderClicked" Tag="{Binding}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left"
                                                    Padding="8,6" Margin="4,4,4,2" CornerRadius="3" Cursor="Hand">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource CoreBlueSteel800}" />
                                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource CoreBlueSteel900}" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource CoreCream}" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource CoreCream}" />
                                                </Button.Resources>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Border Width="3" CornerRadius="1.5"
                                                            Background="{Binding CategoryBrush}"
                                                            VerticalAlignment="Stretch" />
                                                    <TextBlock Text="&#x25BC;" FontSize="9"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding IsExpanded}" />
                                                    <TextBlock Text="&#x25B6;" FontSize="9"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding !IsExpanded}" />
                                                    <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextMutedBrush}" />
                                                </StackPanel>
                                            </Button>
                                            <!-- Collapsible template list -->
                                            <ItemsControl ItemsSource="{Binding Templates}"
                                                          IsVisible="{Binding IsExpanded}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Click="OnTemplateClicked"
                                                                Tag="{Binding}"
                                                                Background="Transparent"
                                                                HorizontalAlignment="Stretch"
                                                                HorizontalContentAlignment="Left"
                                                                Padding="16,5,8,5" Margin="4,2" CornerRadius="3"
                                                                Cursor="Hand">
                                                            <Button.Resources>
                                                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource CoreBlueSteel800}" />
                                                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource CoreBlueSteel900}" />
                                                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource CoreCream}" />
                                                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource CoreCream}" />
                                                            </Button.Resources>
                                                            <StackPanel Spacing="1">
                                                                <TextBlock Text="{Binding Name}" FontSize="12"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                                                <TextBlock Text="{Binding Description}" FontSize="10"
                                                                           Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </SplitView.Pane>

                <!-- Content: Canvas + Right Properties -->
                <SplitView.Content>
                    <DockPanel>
                        <Border DockPanel.Dock="Right" Width="360"
                                Background="{DynamicResource BgSurfaceBrush}"
                                BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="1,0,0,0"
                                IsVisible="{Binding SelectedNode, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Padding="12"
                                        IsVisible="{Binding SelectedNode, Converter={x:Static ObjectConverters.IsNull}}"
                                        BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="0,0,0,1">
                                    <TextBlock Text="Click a node to edit its properties" FontSize="12"
                                               Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" />
                                </Border>

                                <Border IsVisible="{Binding SelectedNode, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel Spacing="6" Margin="12,10">
                                            <TextBlock Text="{Binding SelectedNode.Title}" FontSize="16" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding SelectedNode.Category}" FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />

                                            <TextBlock Text="Title" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                                            <TextBox Text="{Binding SelectedNode.Title, Mode=TwoWay}"
                                                     Background="{DynamicResource BgSecondaryBrush}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                                     Padding="8,5" CornerRadius="3" FontSize="12" />

                                            <TextBlock Text="Output Variable" FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0" />
                                            <TextBox Text="{Binding SelectedNode.OutputVariable, Mode=TwoWay}"
                                                     Watermark="(auto)"
                                                     Background="{DynamicResource BgPrimaryBrush}"
                                                     Foreground="{DynamicResource TextTertiaryBrush}"
                                                     BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                                     Padding="8,5" CornerRadius="3"
                                                     FontFamily="{DynamicResource FontMono}" FontSize="12" />

                                            <Border Height="1" Background="{DynamicResource BorderPrimaryBrush}" Margin="0,6" />

                                            <!-- Validation issues for the selected node. Hidden when empty. -->
                                            <StackPanel IsVisible="{Binding SelectedNode.HasIssues}" Margin="0,0,0,6">
                                                <TextBlock Text="ISSUES" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextDeleteLightBrush}"
                                                           Margin="0,2,0,4" />
                                                <ItemsControl ItemsSource="{Binding SelectedNode.Issues}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{DynamicResource BgDeleteTintBrush}"
                                                                    CornerRadius="3" Padding="8,4" Margin="0,0,0,3">
                                                                <TextBlock Text="{Binding Message}"
                                                                           TextWrapping="Wrap" FontSize="11"
                                                                           Foreground="{DynamicResource TextDeleteLightBrush}" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Border Height="1" Background="{DynamicResource BorderPrimaryBrush}" Margin="0,6" />
                                            </StackPanel>

                                            <TextBlock Text="PARAMETERS" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       Margin="0,2,0,4" />

                                            <!-- Parameter set picker — only visible when the cmdlet declares multiple sets. -->
                                            <StackPanel IsVisible="{Binding SelectedNode.HasMultipleSets}"
                                                        Spacing="3" Margin="0,0,0,6">
                                                <TextBlock Text="Parameter Set" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}" />
                                                <ComboBox ItemsSource="{Binding SelectedNode.KnownParameterSets}"
                                                          SelectedItem="{Binding SelectedNode.ActiveParameterSet, Mode=TwoWay}"
                                                          Background="{DynamicResource BgPrimaryBrush}"
                                                          Foreground="{DynamicResource TextTertiaryBrush}"
                                                          BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                                          Padding="8,5" CornerRadius="3"
                                                          FontFamily="{DynamicResource FontMono}" FontSize="12"
                                                          HorizontalAlignment="Stretch"
                                                          HorizontalContentAlignment="Left"
                                                          VerticalContentAlignment="Center">
                                                    <!-- Highlight the currently-selected item inside the dropdown so
                                                         users can see which set is active at a glance. FluentAvalonia's
                                                         defaults for ComboBoxItem don't pop against our dark tokens. -->
                                                    <ComboBox.Styles>
                                                        <Style Selector="ComboBoxItem">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                        </Style>
                                                        <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
                                                            <Setter Property="Background" Value="{DynamicResource BgSaveTintBrush}" />
                                                            <Setter Property="TextElement.Foreground" Value="{DynamicResource TextFileBrush}" />
                                                        </Style>
                                                        <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
                                                            <Setter Property="Background" Value="{DynamicResource BgSecondaryBrush}" />
                                                        </Style>
                                                        <Style Selector="ComboBoxItem:selected:pointerover /template/ ContentPresenter">
                                                            <Setter Property="Background" Value="{DynamicResource BgSaveTintBrush}" />
                                                        </Style>
                                                    </ComboBox.Styles>
                                                </ComboBox>
                                            </StackPanel>

                                            <ItemsControl ItemsSource="{Binding SelectedNode.Parameters}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Spacing="3" Margin="0,0,0,8"
                                                                    IsVisible="{Binding ShouldRenderInPanel}">
                                                            <!-- Header (hidden for Bool — the CheckBox label replaces it) -->
                                                            <StackPanel Orientation="Horizontal" Spacing="4"
                                                                        IsVisible="{Binding !IsBool}">
                                                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                                                <TextBlock Text="*" FontSize="12" FontWeight="Bold"
                                                                           Foreground="{DynamicResource TextDeleteBrush}"
                                                                           IsVisible="{Binding IsEffectivelyMandatory}" />
                                                                <TextBlock Text="{Binding Type, StringFormat='[{0}]'}" FontSize="9"
                                                                           Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                            <!-- Per-parameter help. Truncated to ~2 lines in-panel; full
                                                                 text surfaces on hover so long Get-Help descriptions
                                                                 don't blow out the panel while staying discoverable. -->
                                                            <TextBlock Text="{Binding Description}" FontSize="10"
                                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                                       TextWrapping="Wrap"
                                                                       MaxLines="2"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip.Tip="{Binding Description}"
                                                                       ToolTip.ShowDelay="300"
                                                                       IsVisible="{Binding !IsBool}" />

                                                            <!-- Wired chip: replaces the literal editor when a wire feeds this parameter's pin. -->
                                                            <Border IsVisible="{Binding IsWired}"
                                                                    Background="{DynamicResource BgSecondaryBrush}"
                                                                    BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                                                    BorderThickness="1" CornerRadius="10"
                                                                    Padding="8,3" HorizontalAlignment="Left">
                                                                <TextBlock Text="{Binding WiredFromLabel}" FontSize="11"
                                                                           Foreground="{DynamicResource TextFileBrush}"
                                                                           FontFamily="{DynamicResource FontMono}" />
                                                            </Border>

                                                            <!-- Literal editors: hidden while wired. One outer gate, type-specific inner toggles. -->
                                                            <StackPanel IsVisible="{Binding IsUnwired}" Spacing="3">
                                                                <!-- Bool → CheckBox -->
                                                                <CheckBox IsChecked="{Binding BoolValue, Mode=TwoWay}"
                                                                          IsVisible="{Binding IsBool}"
                                                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                                                          FontSize="13"
                                                                          HorizontalAlignment="Left"
                                                                          VerticalContentAlignment="Center"
                                                                          Padding="8,4" Margin="0,2">
                                                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                                                </CheckBox>
                                                                <!-- Enum → ComboBox -->
                                                                <ComboBox ItemsSource="{Binding EnumOptions}"
                                                                          SelectedItem="{Binding SelectedEnumValue, Mode=TwoWay}"
                                                                          IsVisible="{Binding IsEnum}"
                                                                          Background="{DynamicResource BgPrimaryBrush}"
                                                                          Foreground="{DynamicResource TextTertiaryBrush}"
                                                                          BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                                                          Padding="8,5" CornerRadius="3"
                                                                          FontFamily="{DynamicResource FontMono}" FontSize="12"
                                                                          HorizontalAlignment="Stretch"
                                                                          HorizontalContentAlignment="Left"
                                                                          VerticalContentAlignment="Center" />
                                                                <!-- Everything else → TextBox -->
                                                                <TextBox Text="{Binding Value, Mode=TwoWay}"
                                                                         Watermark="{Binding DefaultValue}"
                                                                         IsVisible="{Binding IsTextInput}"
                                                                         Background="{DynamicResource BgPrimaryBrush}"
                                                                         Foreground="{DynamicResource TextTertiaryBrush}"
                                                                         BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                                                         Padding="8,5" CornerRadius="3"
                                                                         FontFamily="{DynamicResource FontMono}" FontSize="12" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- ── Function Arguments Section ── -->
                                            <StackPanel IsVisible="{Binding SelectedNode.IsFunctionContainer}">
                                                <Border Height="1" Background="{DynamicResource BorderPrimaryBrush}" Margin="0,4" />

                                                <DockPanel Margin="0,2,0,4">
                                                    <Button DockPanel.Dock="Right" Content="+ Add"
                                                            Command="{Binding AddArgumentCommand}"
                                                            Padding="8,3" CornerRadius="3" FontSize="11"
                                                            Background="{DynamicResource BgSaveTintBrush}"
                                                            Foreground="{DynamicResource TextFileBrush}"
                                                            VerticalAlignment="Center">
                                                        <Button.Resources>
                                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource CoreBlueSteel700}" />
                                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource CoreBlueSteel900}" />
                                                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource CoreBlueBright200}" />
                                                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource CoreBlueBright300}" />
                                                        </Button.Resources>
                                                    </Button>
                                                    <TextBlock Text="ARGUMENTS" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               VerticalAlignment="Center" />
                                                </DockPanel>

                                                <ItemsControl ItemsSource="{Binding SelectedNode.Parameters}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel IsVisible="{Binding IsArgument}" Spacing="4" Margin="0,0,0,8">
                                                                <DockPanel>
                                                                    <Button DockPanel.Dock="Right" Content="&#x2715;"
                                                                            Command="{Binding #RootWindow.DataContext.RemoveArgumentCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            Padding="6,2" CornerRadius="3" FontSize="11"
                                                                            Background="{DynamicResource BgDeleteTintBrush}"
                                                                            Foreground="{DynamicResource TextDeleteLightBrush}"
                                                                            VerticalAlignment="Center" Margin="4,0,0,0">
                                                                        <Button.Resources>
                                                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource CoreRedWarning700}" />
                                                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource CoreRedWarning900}" />
                                                                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource CoreRedWarning200}" />
                                                                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource CoreRedWarning300}" />
                                                                        </Button.Resources>
                                                                    </Button>
                                                                    <TextBox Text="{Binding Name, Mode=TwoWay}"
                                                                             Watermark="ParamName"
                                                                             Background="{DynamicResource BgPrimaryBrush}"
                                                                             Foreground="{DynamicResource TextTertiaryBrush}"
                                                                             BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                                                             Padding="8,4" CornerRadius="3"
                                                                             FontFamily="{DynamicResource FontMono}" FontSize="12" />
                                                                </DockPanel>
                                                                <Grid ColumnDefinitions="*,Auto,Auto">
                                                                    <ComboBox Grid.Column="0"
                                                                              ItemsSource="{x:Static vm:GraphCanvasViewModel.ArgumentTypeOptions}"
                                                                              SelectedItem="{Binding Type, Mode=TwoWay}"
                                                                              Background="{DynamicResource BgPrimaryBrush}"
                                                                              Foreground="{DynamicResource TextTertiaryBrush}"
                                                                              BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                                                              Padding="8,4" CornerRadius="3" FontSize="11"
                                                                              HorizontalAlignment="Stretch" Margin="0,0,4,0" />
                                                                    <CheckBox Grid.Column="1" Content="Required"
                                                                              IsChecked="{Binding IsMandatory, Mode=TwoWay}"
                                                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                                                              FontSize="11" Padding="4,2" Margin="4,0" VerticalContentAlignment="Center" />
                                                                    <CheckBox Grid.Column="2" Content="Pipeline"
                                                                              IsChecked="{Binding IsPipelineInput, Mode=TwoWay}"
                                                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                                                              FontSize="11" Padding="4,2" Margin="4,0" VerticalContentAlignment="Center" />
                                                                </Grid>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <StackPanel IsVisible="{Binding !SelectedNode.IsCmdletNode}">
                                                <Border Height="1" Background="{DynamicResource BorderPrimaryBrush}" Margin="0,4" />

                                                <TextBlock Text="SCRIPT BODY" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           Margin="0,2,0,4" />
                                                <TextBox Text="{Binding SelectedNode.ScriptBody, Mode=TwoWay}"
                                                         AcceptsReturn="True" TextWrapping="Wrap"
                                                         Height="120"
                                                         Background="{DynamicResource BgPrimaryBrush}"
                                                         Foreground="{DynamicResource TextTertiaryBrush}"
                                                         BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                                         Padding="8,6" CornerRadius="3"
                                                         FontFamily="{DynamicResource FontMono}" FontSize="11" />
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </DockPanel>
                        </Border>

                        <ctrl:NodeGraphCanvas x:Name="GraphCanvas" DataContext="{Binding}" />
                    </DockPanel>
                </SplitView.Content>
            </SplitView>

            <!-- ── Row 1: GridSplitter ── -->
            <GridSplitter x:Name="PreviewSplitter" Grid.Row="1"
                          Height="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderPrimaryBrush}"
                          IsVisible="False" />

            <!-- ── Row 2: Script Panel (resizable) ── -->
            <Border x:Name="PreviewPanel" Grid.Row="2"
                    Background="{DynamicResource BgPrimaryBrush}"
                    BorderBrush="{DynamicResource BorderPrimaryBrush}"
                    BorderThickness="0,1,0,0"
                    IsVisible="False">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="12,6"
                            Background="{DynamicResource BgSecondaryBrush}"
                            BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock Text="Script Preview" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                <Button Content="Copy" Click="OnCopyPreviewClicked"
                                        Background="{DynamicResource BgSecondaryBrush}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Padding="8,3" CornerRadius="3" FontSize="11">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource CoreBlueSteel800}" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource CoreBlueSteel900}" />
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource CoreCream}" />
                                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource CoreCream}" />
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <TextBox x:Name="PreviewTextBox"
                             IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                             Background="{DynamicResource BgPrimaryBrush}"
                             Foreground="#FF72BFB0"
                             BorderThickness="0"
                             Padding="12,8"
                             FontFamily="{DynamicResource FontMono}" FontSize="12" />
                </DockPanel>
            </Border>
        </Grid>

    </DockPanel>

    <!-- ══════ Quick-add popup (Tab / wire drop on empty / right-click → Quick add). ══════
         Placed anchored at the cursor via Margin bound to QuickAdd.X / .Y. -->
    <Border IsVisible="{Binding QuickAdd.IsOpen}"
            Background="Transparent"
            PointerPressed="OnQuickAddBackgroundPressed">
        <Border x:Name="QuickAddPanel"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="{Binding QuickAdd.CursorMargin}"
                Width="380" MaxHeight="480"
                Background="{DynamicResource BgPrimaryBrush}"
                BorderBrush="{DynamicResource BorderPrimaryBrush}"
                BorderThickness="1" CornerRadius="6"
                Padding="8"
                BoxShadow="0 4 12 0 #99000000"
                PointerPressed="OnQuickAddPanelPressed">
            <DockPanel LastChildFill="True">
                <!-- Chip row: compatibility chip (when drag-initiated) + tag chips -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="0,0,0,6">
                    <ToggleButton IsChecked="{Binding QuickAdd.CompatibleOnly, Mode=TwoWay}"
                                  IsVisible="{Binding QuickAdd.HasSourcePort}"
                                  Content="{Binding QuickAdd.CompatibilityChipLabel}"
                                  Classes="tagChip"
                                  Padding="8,3" CornerRadius="10"
                                  FontSize="10"
                                  FontFamily="{DynamicResource FontMono}" />
                    <ItemsControl ItemsSource="{Binding QuickAdd.TagChips}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ToggleButton IsChecked="{Binding IsActive, Mode=TwoWay}"
                                              Content="{Binding Label}"
                                              Classes="tagChip"
                                              Padding="8,3" CornerRadius="10"
                                              FontSize="10"
                                              FontFamily="{DynamicResource FontMono}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Search box: focused on open, first key goes here -->
                <TextBox DockPanel.Dock="Top" x:Name="QuickAddSearchBox"
                         Text="{Binding QuickAdd.SearchText, Mode=TwoWay}"
                         Watermark="Type to filter..."
                         Background="{DynamicResource BgSecondaryBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderPrimaryBrush}"
                         Padding="8,6" CornerRadius="3" FontSize="12"
                         Margin="0,0,0,6"
                         KeyDown="OnQuickAddSearchKeyDown" />

                <!-- Results: categorized collapsible rows, auto-expanded when search is active -->
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding QuickAdd.FilteredCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,1">
                                    <Button Click="OnQuickAddCategoryClicked" Tag="{Binding}"
                                            Background="Transparent" BorderThickness="0"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="6,4" Margin="0,1" CornerRadius="3" Cursor="Hand">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource CoreBlueSteel800}" />
                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource CoreBlueSteel900}" />
                                        </Button.Resources>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Border Width="3" CornerRadius="1.5"
                                                    Background="{Binding CategoryBrush}"
                                                    VerticalAlignment="Stretch" />
                                            <TextBlock Text="&#x25BC;" FontSize="9"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding IsExpanded}" />
                                            <TextBlock Text="&#x25B6;" FontSize="9"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding !IsExpanded}" />
                                            <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextMutedBrush}" />
                                            <TextBlock Text="{Binding Items.Count, StringFormat='({0})'}"
                                                       FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <ItemsControl ItemsSource="{Binding Items}"
                                                  IsVisible="{Binding IsExpanded}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Click="OnQuickAddTemplateClicked"
                                                        Tag="{Binding Template}"
                                                        Classes.quickAddSelected="{Binding IsSelected}"
                                                        Background="Transparent"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        Padding="14,4,6,4" Margin="0,1" CornerRadius="3"
                                                        Cursor="Hand">
                                                    <Button.Resources>
                                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource CoreBlueSteel800}" />
                                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource CoreBlueSteel900}" />
                                                    </Button.Resources>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Template.Name}" FontSize="12"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                                        <TextBlock Text="{Binding Template.Description}" FontSize="10"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   TextTrimming="CharacterEllipsis" MaxWidth="340" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Border>

    <!-- ══════ Cheat sheet overlay (toggled by ?) — last child so it renders on top. ══════ -->
    <Border IsVisible="{Binding IsCheatSheetOpen}"
            Background="#CC060D16">
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                MinWidth="460" MaxWidth="640" Padding="24,20"
                Background="{DynamicResource BgPrimaryBrush}"
                BorderBrush="{DynamicResource BorderPrimaryBrush}"
                BorderThickness="1" CornerRadius="8">
            <StackPanel Spacing="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left"
                               Text="Keyboard Shortcuts"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock DockPanel.Dock="Right"
                               Text="Esc / ? to close"
                               FontSize="10"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right" />
                </DockPanel>
                <Border Height="1" Background="{DynamicResource BorderPrimaryBrush}" />

                <!-- Two columns: shortcut ∷ description -->
                <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                      RowSpacing="4">
                    <TextBlock Grid.Row="0"  Grid.Column="0" Text="Ctrl+N"       Classes="cheatKey"/>
                    <TextBlock Grid.Row="0"  Grid.Column="1" Text="New graph"    Classes="cheatLabel"/>
                    <TextBlock Grid.Row="1"  Grid.Column="0" Text="Ctrl+O"       Classes="cheatKey"/>
                    <TextBlock Grid.Row="1"  Grid.Column="1" Text="Open .pblx project" Classes="cheatLabel"/>
                    <TextBlock Grid.Row="2"  Grid.Column="0" Text="Ctrl+S"       Classes="cheatKey"/>
                    <TextBlock Grid.Row="2"  Grid.Column="1" Text="Save .pblx"   Classes="cheatLabel"/>
                    <TextBlock Grid.Row="3"  Grid.Column="0" Text="Ctrl+E"       Classes="cheatKey"/>
                    <TextBlock Grid.Row="3"  Grid.Column="1" Text="Export .ps1"  Classes="cheatLabel"/>
                    <TextBlock Grid.Row="4"  Grid.Column="0" Text="F5"           Classes="cheatKey"/>
                    <TextBlock Grid.Row="4"  Grid.Column="1" Text="Run generated script"  Classes="cheatLabel"/>
                    <TextBlock Grid.Row="5"  Grid.Column="0" Text="Alt+S"        Classes="cheatKey"/>
                    <TextBlock Grid.Row="5"  Grid.Column="1" Text="Toggle script preview" Classes="cheatLabel"/>
                    <TextBlock Grid.Row="6"  Grid.Column="0" Text="P"            Classes="cheatKey"/>
                    <TextBlock Grid.Row="6"  Grid.Column="1" Text="Toggle palette"        Classes="cheatLabel"/>
                    <TextBlock Grid.Row="7"  Grid.Column="0" Text="/"            Classes="cheatKey"/>
                    <TextBlock Grid.Row="7"  Grid.Column="1" Text="Focus palette search"  Classes="cheatLabel"/>
                    <TextBlock Grid.Row="8"  Grid.Column="0" Text="Ctrl+D"       Classes="cheatKey"/>
                    <TextBlock Grid.Row="8"  Grid.Column="1" Text="Duplicate selected node" Classes="cheatLabel"/>
                    <TextBlock Grid.Row="14" Grid.Column="0" Text="C"            Classes="cheatKey"/>
                    <TextBlock Grid.Row="14" Grid.Column="1" Text="Collapse / expand selected node" Classes="cheatLabel"/>
                    <TextBlock Grid.Row="15" Grid.Column="0" Text="Tab"          Classes="cheatKey"/>
                    <TextBlock Grid.Row="15" Grid.Column="1" Text="Quick add popup at cursor (or drag wire onto empty space)" Classes="cheatLabel"/>
                    <TextBlock Grid.Row="16" Grid.Column="0" Text="Ctrl+Z"       Classes="cheatKey"/>
                    <TextBlock Grid.Row="16" Grid.Column="1" Text="Undo"         Classes="cheatLabel"/>
                    <TextBlock Grid.Row="17" Grid.Column="0" Text="Ctrl+Y"       Classes="cheatKey"/>
                    <TextBlock Grid.Row="17" Grid.Column="1" Text="Redo (also Ctrl+Shift+Z)" Classes="cheatLabel"/>
                    <TextBlock Grid.Row="9"  Grid.Column="0" Text="Del / Backspace" Classes="cheatKey"/>
                    <TextBlock Grid.Row="9"  Grid.Column="1" Text="Delete selected node" Classes="cheatLabel"/>
                    <TextBlock Grid.Row="10" Grid.Column="0" Text="F"            Classes="cheatKey"/>
                    <TextBlock Grid.Row="10" Grid.Column="1" Text="Zoom to fit (selection or all)" Classes="cheatLabel"/>
                    <TextBlock Grid.Row="11" Grid.Column="0" Text="Ctrl+0"       Classes="cheatKey"/>
                    <TextBlock Grid.Row="11" Grid.Column="1" Text="Reset view"   Classes="cheatLabel"/>
                    <TextBlock Grid.Row="12" Grid.Column="0" Text="Esc"          Classes="cheatKey"/>
                    <TextBlock Grid.Row="12" Grid.Column="1" Text="Cancel drag · deselect · close overlay" Classes="cheatLabel"/>
                    <TextBlock Grid.Row="13" Grid.Column="0" Text="?"            Classes="cheatKey"/>
                    <TextBlock Grid.Row="13" Grid.Column="1" Text="Toggle this cheat sheet" Classes="cheatLabel"/>
                </Grid>
            </StackPanel>
        </Border>
    </Border>
    </Grid>
</uiw:AppWindow>
